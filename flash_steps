1) Compile application files

arm-none-eabi-gcc \
  -mcpu=cortex-m7 \
  -mthumb \
  -O0 \
  -g \
  -Wall \
  -ffreestanding \
  -nostdlib \
  -Iinc \
  -c src/main.c -o main.o

arm-none-eabi-gcc \
  -mcpu=cortex-m7 \
  -mthumb \
  -O0 \
  -g \
  -ffreestanding \
  -nostdlib \
  -c src/system_stm32h7xx.c -o system.o

arm-none-eabi-gcc \
  -mcpu=cortex-m7 \
  -mthumb \
  -O0 \
  -g \
  -ffreestanding \
  -nostdlib \
  -c src/system_stm32h7xx.c -o system.o

2) Assemble startup

arm-none-eabi-gcc \
  -mcpu=cortex-m7 \
  -mthumb \
  -x assembler-with-cpp \
  -c startup/startup_stm32h753xx.s -o startup.o

3) Link

arm-none-eabi-gcc \
  -mcpu=cortex-m7 \
  -mthumb \
  -T ld/STM32H743ZITx_FLASH_DTCMRAM.ld \
  -nostdlib \
  -nostartfiles \
  startup.o system.o syscalls.o main.o \
  -o blinky.elf

4) Convert to raw binary

arm-none-eabi-objcopy -O binary blinky.elf blinky.bin

5) Flash

st-flash write blinky.bin 0x08000000


